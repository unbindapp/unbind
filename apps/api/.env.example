GOPRIVATE=github.com/unbindapp
PORT=8089
KUBECONFIG=./.data/kubernetes/k3d.kubeconfig.yaml
POSTGRES_HOST=localhost
POSTGRES_PORT=53337
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=unbind
# In-cluster builder jobs cannot reach localhost; compose also publishes postgres on docker0
BUILDER_POSTGRES_HOST=172.17.0.1
EXTERNAL_OAUTH2_URL=http://localhost:8089
# Generated service domains become <name>-<rand>.localhost, served by the k3d
# load balancer on ports 80/443
BOOTSTRAP_WILDCARD_BASE_URL=http://localhost
TOKEN_AUDIENCE=unbind-api
COOKIE_SECURE=false
REDIS_URL=localhost:63234
BOOTSTRAP_CONTAINER_REGISTRY_HOST=docker-registry.unbind-system:5000
BOOTSTRAP_CONTAINER_REGISTRY_USER=unbind
BOOTSTRAP_CONTAINER_REGISTRY_PASSWORD=1234
CONTAINER_REGISTRY_PASSWORD=1234
BUILDKIT_HOST=tcp://buildkit.unbind-system:1234
LOKI_ENDPOINT=http://localhost:3100
PROMETHEUS_ENDPOINT=http://localhost:8428
SYSTEM_NAMESPACE=unbind-system
SKIP_BOOTSTRAP=false
INJECT_DEV_ORIGINS=true
