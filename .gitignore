# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Web (apps/web) ---
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
apps/web/dist
apps/web/src/routeTree.gen.ts
*.tsbuildinfo
.tanstack
.vercel


# --- Compiled Go binaries / build output ---
apps/*/bin/
apps/api/cmd/api/api
apps/api/cmd/cli/cli
apps/api/cmd/builder/builder
# Binaries built from a module root, e.g. `cd apps/api && go build ./cmd/api`
apps/api/api
apps/api/cli
apps/api/builder
apps/operator/manager
apps/installer/installer
apps/installer/unbind-installer-*
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum
# Embedded SPA build, copied in at image build time (keep the stub)
apps/api/internal/web/dist/*
!apps/api/internal/web/dist/index.html
# Local dev infra state (docker-compose volumes)
deploy/compose/.data/*/**
!deploy/compose/.data/*/.gitkeep
apps/api/.data/*/**
!apps/api/.data/*/.gitkeep

# --- Generated / shared ---
go-openapi.yaml

# --- Misc ---
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env*
.claude/*
!.claude/skills
MIGRATION_PLAN.md
